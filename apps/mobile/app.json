{
  "expo": {
    "name": "Wellnest",
    "slug": "wellnest",
    "scheme": "wellnest",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "bundleIdentifier": "com.wellnest.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Wellnest uses your location to pin your service address and show provider ETA for active bookings only."
      }
    },
    "android": {
      "package": "com.wellnest.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "4906aa38-22b3-4b14-a430-4aba3cd2e0b8"
      }
    },
    "owner": "plugwattanachai",
    "plugins": [
      "expo-secure-store"
    ]
  }
}
