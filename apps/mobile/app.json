{
  "expo": {
    "name": "Wellnest",
    "slug": "wellnest",
    "scheme": "wellnest",
    "version": "0.1.7",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "updates": {
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/4906aa38-22b3-4b14-a430-4aba3cd2e0b8"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "bundleIdentifier": "com.plugwattanachai.wellnest",
      "buildNumber": "12",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Wellnest uses your location to pin your service address and show provider ETA for active bookings only."
      }
    },
    "android": {
      "package": "com.wellnest.app",
      "versionCode": 8,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "4906aa38-22b3-4b14-a430-4aba3cd2e0b8"
      }
    },
    "owner": "plugwattanachai",
    "plugins": [
      "./plugins/with-local-react-native-cli-autolinking",
      "./plugins/with-ios-fmt-cxx17",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": false
        }
      ],
      "expo-asset"
    ]
  }
}
