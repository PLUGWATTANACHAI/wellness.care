{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://wellnest-api-staging.onrender.com"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://wellnest-api-staging.onrender.com"
      },
      "ios": {
        "simulator": false,
        "image": "latest"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "testflight": {
      "credentialsSource": "local",
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://wellnest-api-staging.onrender.com"
      },
      "ios": {
        "simulator": false,
        "image": "latest"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6789550857",
        "ascApiKeyId": "K67T5B6XFM",
        "ascApiKeyIssuerId": "27b192eb-d864-42b0-998e-a04cfc916182",
        "ascApiKeyPath": "ios/certs/AuthKey_K67T5B6XFM.p8"
      },
      "android": {}
    }
  }
}
